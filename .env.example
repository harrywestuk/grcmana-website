# Supabase PostgreSQL connection string (pooling mode)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Used to encrypt JWT tokens (32+ characters)
PAYLOAD_SECRET=YOUR_SECRET_HERE_MIN_32_CHARS

# Canonical URL — no trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Resend email API key
RESEND_API_KEY=re_YOUR_KEY_HERE

# S3-compatible storage (Supabase Storage / any S3)
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_REGION=your-region
S3_ENDPOINT=https://your-endpoint.supabase.co/storage/v1/s3

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE
